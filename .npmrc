public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
enable-pre-post-scripts=true
# Allow build scripts for critical packages (required for Vercel deployment)
onlyBuiltDependencies[]=sharp
onlyBuiltDependencies[]=@vercel/speed-insights
onlyBuiltDependencies[]=esbuild
onlyBuiltDependencies[]=core-js
onlyBuiltDependencies[]=msw
onlyBuiltDependencies[]=protobufjs
